{
  "name": "multiview-devtools",
  "version": "0.1.0",
  "description": "Electron multi-webContents DevTools manager package with a bundled Vue-based manager UI.",
  "license": "MIT",
  "author": "Vsevolod Kulagin <k00lagin@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k00lagin/multiview-devtools.git"
  },
  "homepage": "https://github.com/k00lagin/multiview-devtools#readme",
  "bugs": {
    "url": "https://github.com/k00lagin/multiview-devtools/issues"
  },
  "keywords": [
    "electron",
    "devtools",
    "webcontents",
    "webcontentsview",
    "debugging"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.7",
  "peerDependencies": {
    "electron": ">=41 <42"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "bun run clean && bun run build:renderer && bun run build:package",
    "build:renderer": "vite build",
    "build:package": "tsc -p tsconfig.build.json && node ./scripts/prepare-dist.mjs",
    "prepack": "bun run build",
    "dev": "bun run build && node ./scripts/run-electron.mjs ./dev",
    "smoke:pack": "node ./scripts/run-pack-smoke.mjs",
    "check:release": "bun run lint && bun run typecheck && bun run smoke:pack",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src dev scripts eslint.config.mjs vite.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.0.2",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
