{
  "name": "multiview-devtools",
  "version": "0.1.0",
  "description": "Electron multi-webContents DevTools manager package with a bundled Vue-based manager UI.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.7"
  },
  "packageManager": "bun@1.3.7",
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "bun run clean && bun run build:renderer && bun run build:package",
    "build:renderer": "vite build",
    "build:package": "tsup --config tsup.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.0.2",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
